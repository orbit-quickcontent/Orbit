# Orbit Platform — Production Environment Configuration Template

# 1. Database Connection (PostgreSQL)
# SQLite is used in development. PostgreSQL is required for production.
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<db>?sslmode=require"

# 2. AWS S3 Credentials (for Footage & Logo Storage)
# If missing, the app falls back to local uploads (unsuitable for production/serverless).
AWS_ACCESS_KEY_ID="your-production-access-key-id"
AWS_SECRET_ACCESS_KEY="your-production-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET_NAME="orbit-production-vault"

# 3. Email Gateway (Gmail SMTP)
# Configured for real email/OTP transmission.
GMAIL_USER="your-verified-sender@gmail.com"
GMAIL_APP_PASSWORD="your-google-app-password"

# 4. Payment Gateway (Razorpay)
# For processing real INR transactions.
RAZORPAY_KEY_ID="rzp_live_production_id"
RAZORPAY_KEY_SECRET="production_secret_key"
RAZORPAY_WEBHOOK_SECRET="webhook_signature_secret"

# 5. Domain / WebSocket URLs
# NextAuth configuration
NEXTAUTH_SECRET="supersecretjwtsignkeyfororbitauthproduction2026!"
NEXTAUTH_URL="https://admin.orbit.com"
EXPO_PUBLIC_API_URL="https://admin.orbit.com"
WEBSOCKET_SERVICE_URL="https://your-websocket-service-domain.com"
