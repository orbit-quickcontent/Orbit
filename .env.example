# ====================================================
#   ORBIT Production Configuration Environment variables
# ====================================================

# --- Firebase Admin SDK Configuration ---
# Generate these under Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_PROJECT_ID=orbit-fs
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@orbit-fs.iam.gserviceaccount.com
# Replace \n with actual newlines in your private key string when configuring env in hosting
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# --- Cashfree Payouts Config ---
# Generate these under Cashfree Dashboard -> Payouts -> Developers -> API Keys
CASHFREE_CLIENT_ID=CFXXXXXX
CASHFREE_API_KEY=cfkeyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CASHFREE_ENV=sandbox # Options: sandbox | production

# --- WebSocket Service Scaling ---
# Connection URL for Redis cache (used for scaling WebSockets adapter)
REDIS_URL=redis://redis:6379

# --- Google Maps API Key ---
# Required for mobile apps and locations tracking maps interfaces
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
